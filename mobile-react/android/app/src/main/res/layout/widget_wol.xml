<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/widget_host_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Host Name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#f8f9fa" 
            android:maxLines="1"
            android:ellipsize="end" /> <!-- Colors.text.primary -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/widget_status_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textSize="14sp"
                android:textColor="#adb5bd"
                android:layout_marginEnd="6dp" /> <!-- Colors.status.unknown -->

            <TextView
                android:id="@+id/widget_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unknown"
                android:textSize="12sp"
                android:textColor="#ced4da" /> <!-- Colors.text.secondary -->
        </LinearLayout>

    </LinearLayout>

    <!-- Wake Button Container with Loading State -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp">

        <Button
            android:id="@+id/widget_wake_button"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="WAKE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/widget_button_background"
            android:gravity="center" />

        <ProgressBar
            android:id="@+id/widget_loading_indicator"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:indeterminateTint="#FFFFFF"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/widget_success_indicator"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_circle"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
